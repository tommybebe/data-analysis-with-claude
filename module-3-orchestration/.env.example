# ==============================================================================
# Module 3: 권한 오케스트레이션 — 환경 변수 템플릿
# ==============================================================================
# 이 파일을 .env로 복사한 뒤 실제 값을 입력하세요:
#   cp .env.example .env
#
# .env 파일은 .gitignore에 포함되어 Git에 커밋되지 않습니다.
# 서비스 계정 키 파일(.json)도 절대 커밋하지 마세요.
# ==============================================================================

# ------------------------------------------------------------------------------
# [필수] GCP / BigQuery 인증
# ------------------------------------------------------------------------------

# Google Cloud 프로젝트 ID (전 세계에서 고유한 값)
# 예: fittrack-analysis-yourname-2026
GCP_PROJECT_ID=

# GCP 서비스 계정 JSON 키 파일의 절대 경로
# 예: /tmp/fittrack-sa-key.json
# ⚠️ 키 파일 자체는 절대 Git에 커밋하지 마세요
GOOGLE_APPLICATION_CREDENTIALS=

# ------------------------------------------------------------------------------
# [필수] GitHub 리포지토리
# ------------------------------------------------------------------------------

# GitHub 리포지토리 경로 (소유자/리포지토리 형식)
# GitHub Actions 워크플로와 gh CLI 명령에서 사용
# 예: your-username/fittrack-analysis
GITHUB_REPOSITORY=

# ------------------------------------------------------------------------------
# [선택] BigQuery 데이터셋 이름 (기본값 사용 시 변경 불필요)
# ------------------------------------------------------------------------------

# 원시 이벤트 데이터 적재 대상 데이터셋
BQ_DATASET_RAW=raw

# dbt 변환 결과 출력 데이터셋
BQ_DATASET_ANALYTICS=analytics

# BigQuery 데이터셋 물리적 위치 (리전)
# 아시아 태평양 사용자는 asia-northeast3 (서울) 권장
# DATASET_LOCATION=US

# ------------------------------------------------------------------------------
# [선택] 합성 데이터 생성 파라미터 (기본값 사용 시 변경 불필요)
# ------------------------------------------------------------------------------
# ⚠️ 수업 환경에서는 기본값 유지 권장 — 값을 늘리면 BigQuery 비용이 증가합니다

# SYNTHETIC_NUM_USERS=10000
# SYNTHETIC_START_DATE=2026-01-01
# SYNTHETIC_END_DATE=2026-03-31

# ------------------------------------------------------------------------------
# [참고] BigQuery 비용 가드 — .claude/settings.json에서 관리
# ------------------------------------------------------------------------------
# 아래 변수는 .env가 아닌 .claude/settings.json의 env 섹션에서 설정합니다.
# Claude Code가 훅 실행 시 자동으로 환경 변수로 주입합니다.
#
# BQ_COST_LIMIT_BYTES=536870912  (500 MB, 기본값)

# ------------------------------------------------------------------------------
# [CI 전용] GitHub Actions 인증 — GitHub Repository Secret으로 등록
# ------------------------------------------------------------------------------
# 로컬에서는 설정 불필요 — `claude login`으로 인증합니다.
# GitHub Settings → Secrets and variables → Actions → New repository secret
#
# CLAUDE_TOKEN=  (Claude 인증 토큰)
